# Fail2ban filter for Arr-stack applications (Sonarr, Radarr, etc.)

[Definition]

# Match failed authentication attempts in Arr-stack logs
failregex = ^.*\[Warn\].*Authentication.*failed.*from.*<HOST>.*$
            ^.*\[Error\].*Unauthorized.*<HOST>.*$
            ^.*\[Info\].*Login.*failed.*<HOST>.*$

# Ignore successful authentications
ignoreregex = ^.*\[Info\].*Authentication.*successful.*$
              ^.*\[Debug\].*$
