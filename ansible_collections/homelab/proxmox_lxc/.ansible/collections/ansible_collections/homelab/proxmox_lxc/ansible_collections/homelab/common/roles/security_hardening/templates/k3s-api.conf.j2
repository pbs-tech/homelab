# Fail2ban filter for K3s API server
[Definition]

# Match failed authentication attempts in K3s audit logs
failregex = ^.*"user":.*"name":".*","uid":".*".*"verb":".*".*"reason":"Unauthorized".*"sourceIPs":\["<HOST>"\].*$
            ^.*"verb":".*".*"objectRef":.*"reason":"Forbidden".*"sourceIPs":\["<HOST>"\].*$
            ^.*authentication.*failed.*<HOST>.*$
            ^.*TLS handshake error.*<HOST>.*$

# Ignore successful authentications
ignoreregex = ^.*"verb":".*".*"code":20[0-9].*"sourceIPs":\["<HOST>"\].*$
              ^.*authentication.*successful.*<HOST>.*$
