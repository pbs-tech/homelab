server:
  http_listen_address: {{ promtail_listen_address }}
  http_listen_port: {{ promtail_listen_port }}
  grpc_listen_port: {{ promtail_grpc_listen_port }}
  log_level: info

positions:
  filename: {{ promtail_positions_file }}

clients:
  - url: {{ loki_endpoint }}/loki/api/v1/push
    timeout: 10s
    backoff_config:
      min_period: 500ms
      max_period: 5m
      max_retries: 10
    # Basic tenant ID for multi-tenancy (optional)
    # tenant_id: homelab

scrape_configs:
{% for config in promtail_scrape_configs %}
  - job_name: {{ config.job_name }}
{% if config.static_configs is defined %}
    static_configs:
{% for static_config in config.static_configs %}
      - targets:
{% for target in static_config.targets %}
          - {{ target }}
{% endfor %}
        labels:
{% for label_key, label_value in static_config.labels.items() %}
          {{ label_key }}: {{ label_value }}
{% endfor %}
{% endfor %}
{% endif %}
{% if config.journal is defined %}
    journal:
      max_age: {{ config.journal.max_age }}
      labels:
{% for label_key, label_value in config.journal.labels.items() %}
        {{ label_key }}: {{ label_value }}
{% endfor %}
{% endif %}
{% if config.pipeline_stages is defined %}
    pipeline_stages:
{% for stage in config.pipeline_stages %}
{{ stage | to_nice_yaml(indent=6) | indent(6, first=False) }}
{% endfor %}
{% endif %}

{% endfor %}
