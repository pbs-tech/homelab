[Unit]
Description=Prometheus AlertManager
Documentation=https://prometheus.io/docs/alerting/alertmanager/
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User={{ alertmanager_user }}
Group={{ alertmanager_group }}
ExecReload=/bin/kill -HUP $MAINPID
ExecStart={{ alertmanager_bin_dir }}/alertmanager \
  --config.file={{ alertmanager_config_dir }}/alertmanager.yml \
  --storage.path={{ alertmanager_data_dir }} \
  --data.retention={{ alertmanager_data_retention }} \
  --web.listen-address={{ alertmanager_listen_address }}:{{ alertmanager_port }} \
  --cluster.listen-address={{ alertmanager_listen_address }}:{{ alertmanager_cluster_port }}{% if alertmanager_external_url %} \
  --web.external-url={{ alertmanager_external_url }}{% endif %}

SyslogIdentifier=alertmanager
Restart=always
RestartSec=5

# Security hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
PrivateDevices=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
ReadWritePaths={{ alertmanager_data_dir }}
MemoryLimit={{ alertmanager_memory_limit }}

[Install]
WantedBy=multi-user.target
