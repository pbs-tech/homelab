# AlertManager configuration
# Managed by Ansible - DO NOT EDIT MANUALLY

global:
{% if alertmanager_smtp_enabled %}
  smtp_smarthost: '{{ alertmanager_smtp_smarthost }}'
  smtp_from: '{{ alertmanager_smtp_from }}'
{% if alertmanager_smtp_auth_username %}
  smtp_auth_username: '{{ alertmanager_smtp_auth_username }}'
{% endif %}
{% if alertmanager_smtp_auth_password %}
  smtp_auth_password: '{{ alertmanager_smtp_auth_password }}'
{% endif %}
  smtp_require_tls: {{ alertmanager_smtp_require_tls | lower }}
{% if alertmanager_smtp_hello %}
  smtp_hello: '{{ alertmanager_smtp_hello }}'
{% endif %}
{% endif %}
{% if alertmanager_slack_enabled and alertmanager_slack_api_url %}
  slack_api_url: '{{ alertmanager_slack_api_url }}'
{% endif %}
  resolve_timeout: 5m

# Templates for notification messages
templates:
  - '{{ alertmanager_templates_dir }}/*.tmpl'

# The root route must match all alerts
route:
  receiver: '{{ alertmanager_default_receiver }}'
  group_by: {{ alertmanager_group_by | to_json }}
  group_wait: {{ alertmanager_group_wait }}
  group_interval: {{ alertmanager_group_interval }}
  repeat_interval: {{ alertmanager_repeat_interval }}
{% if alertmanager_routes | length > 0 %}
  routes:
{% for route in alertmanager_routes %}
    - receiver: '{{ route.receiver }}'
{% if route.match is defined %}
      match:
{% for key, value in route.match.items() %}
        {{ key }}: '{{ value }}'
{% endfor %}
{% endif %}
{% if route.match_re is defined %}
      match_re:
{% for key, value in route.match_re.items() %}
        {{ key }}: '{{ value }}'
{% endfor %}
{% endif %}
{% if route.matchers is defined %}
      matchers:
{% for matcher in route.matchers %}
        - '{{ matcher }}'
{% endfor %}
{% endif %}
{% if route.group_wait is defined %}
      group_wait: {{ route.group_wait }}
{% endif %}
{% if route.group_interval is defined %}
      group_interval: {{ route.group_interval }}
{% endif %}
{% if route.repeat_interval is defined %}
      repeat_interval: {{ route.repeat_interval }}
{% endif %}
{% if route.continue is defined %}
      continue: {{ route.continue | lower }}
{% endif %}
{% if route.mute_time_intervals is defined %}
      mute_time_intervals: {{ route.mute_time_intervals | to_json }}
{% endif %}
{% endfor %}
{% endif %}

# Notification receivers
receivers:
{% for receiver in alertmanager_receivers %}
  - name: '{{ receiver.name }}'
{% if receiver.email_configs is defined and receiver.email_configs | length > 0 %}
    email_configs:
{% for email in receiver.email_configs %}
      - to: '{{ email.to }}'
{% if email.send_resolved is defined %}
        send_resolved: {{ email.send_resolved | lower }}
{% endif %}
{% if email.html is defined %}
        html: '{{ email.html }}'
{% endif %}
{% if email.headers is defined %}
        headers:
{% for key, value in email.headers.items() %}
          {{ key }}: '{{ value }}'
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}
{% if receiver.slack_configs is defined and receiver.slack_configs | length > 0 %}
    slack_configs:
{% for slack in receiver.slack_configs %}
      - channel: '{{ slack.channel }}'
{% if slack.send_resolved is defined %}
        send_resolved: {{ slack.send_resolved | lower }}
{% endif %}
{% if slack.title is defined %}
        title: '{{ slack.title }}'
{% endif %}
{% if slack.text is defined %}
        text: |
          {{ slack.text | indent(10) }}
{% endif %}
{% if slack.icon_emoji is defined %}
        icon_emoji: '{{ slack.icon_emoji }}'
{% endif %}
{% if slack.username is defined %}
        username: '{{ slack.username }}'
{% endif %}
{% endfor %}
{% endif %}
{% if receiver.webhook_configs is defined and receiver.webhook_configs | length > 0 %}
    webhook_configs:
{% for webhook in receiver.webhook_configs %}
      - url: '{{ webhook.url }}'
{% if webhook.send_resolved is defined %}
        send_resolved: {{ webhook.send_resolved | lower }}
{% endif %}
{% if webhook.max_alerts is defined %}
        max_alerts: {{ webhook.max_alerts }}
{% endif %}
{% if webhook.http_config is defined %}
        http_config:
{% if webhook.http_config.basic_auth is defined %}
          basic_auth:
            username: '{{ webhook.http_config.basic_auth.username }}'
            password: '{{ webhook.http_config.basic_auth.password }}'
{% endif %}
{% endif %}
{% endfor %}
{% endif %}
{% if receiver.pagerduty_configs is defined and receiver.pagerduty_configs | length > 0 %}
    pagerduty_configs:
{% for pd in receiver.pagerduty_configs %}
      - service_key: '{{ pd.service_key }}'
{% if pd.send_resolved is defined %}
        send_resolved: {{ pd.send_resolved | lower }}
{% endif %}
{% if pd.severity is defined %}
        severity: '{{ pd.severity }}'
{% endif %}
{% if pd.description is defined %}
        description: '{{ pd.description }}'
{% endif %}
{% endfor %}
{% endif %}
{% endfor %}

# Inhibition rules
inhibit_rules:
{% for rule in alertmanager_inhibit_rules %}
  - source_matchers:
{% for matcher in rule.source_matchers %}
      - '{{ matcher }}'
{% endfor %}
    target_matchers:
{% for matcher in rule.target_matchers %}
      - '{{ matcher }}'
{% endfor %}
{% if rule.equal is defined %}
    equal: {{ rule.equal | to_json }}
{% endif %}
{% endfor %}
