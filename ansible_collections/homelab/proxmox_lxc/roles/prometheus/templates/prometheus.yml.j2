global:
  scrape_interval: {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_evaluation_interval }}

alerting:
  alertmanagers:
    - static_configs:
        - targets:
          - "{{ alertmanager_ip | default('192.168.0.206') }}:9093"

rule_files:
  - "/etc/prometheus/rules/*.yml"

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:{{ prometheus_port }}']

  - job_name: 'k3s-nodes'
    scheme: https
    tls_config:
      insecure_skip_verify: true
    static_configs:
      - targets:
{% for node in k3s_nodes %}
        - '{{ node.ip }}:9100'  # node-exporter
{% endfor %}

  - job_name: 'k3s-api-server'
    scheme: https
    tls_config:
      insecure_skip_verify: true
      cert_file: /etc/prometheus/k3s-client.crt
      key_file: /etc/prometheus/k3s-client.key
    kubernetes_sd_configs:
      - role: endpoints
        kubeconfig_file: /etc/prometheus/kubeconfig
    relabel_configs:
      - source_labels: [__meta_kubernetes_service_name, __meta_kubernetes_endpoint_port_name]
        action: keep
        regex: kubernetes;https

  - job_name: 'k3s-pods'
    kubernetes_sd_configs:
      - role: pod
        kubeconfig_file: /etc/prometheus/kubeconfig
    tls_config:
      insecure_skip_verify: true
    relabel_configs:
      - source_labels: [__meta_kubernetes_pod_annotation_prometheus_io_scrape]
        action: keep
        regex: true
      - source_labels: [__meta_kubernetes_pod_annotation_prometheus_io_path]
        action: replace
        target_label: __metrics_path__
        regex: (.+)
      - source_labels: [__address__, __meta_kubernetes_pod_annotation_prometheus_io_port]
        action: replace
        regex: ([^:]+)(?::\d+)?;(\d+)
        replacement: $1:$2
        target_label: __address__

  - job_name: 'k3s-cadvisor'
    scheme: https
    metrics_path: /metrics/cadvisor
    tls_config:
      insecure_skip_verify: true
      cert_file: /etc/prometheus/k3s-client.crt
      key_file: /etc/prometheus/k3s-client.key
    kubernetes_sd_configs:
      - role: node
        kubeconfig_file: /etc/prometheus/kubeconfig
    relabel_configs:
      - action: labelmap
        regex: __meta_kubernetes_node_label_(.+)
      - source_labels: [__meta_kubernetes_node_name]
        target_label: node
      - source_labels: [__meta_kubernetes_node_name]
        target_label: instance

  - job_name: 'k3s-kubelet'
    scheme: https
    metrics_path: /metrics
    tls_config:
      insecure_skip_verify: true
      cert_file: /etc/prometheus/k3s-client.crt
      key_file: /etc/prometheus/k3s-client.key
    kubernetes_sd_configs:
      - role: node
        kubeconfig_file: /etc/prometheus/kubeconfig
    relabel_configs:
      - action: labelmap
        regex: __meta_kubernetes_node_label_(.+)
      - source_labels: [__meta_kubernetes_node_name]
        target_label: node
      - source_labels: [__meta_kubernetes_node_name]
        target_label: instance

  - job_name: 'proxmox-pve'
    static_configs:
      - targets:
        - "{{ pve_exporter_ip | default('192.168.0.207') }}:9221"

  - job_name: 'homelab-services'
    static_configs:
      - targets:
        - "{{ grafana_ip | default('192.168.0.201') }}:3000"
        - "{{ traefik_ip | default('192.168.0.205') }}:8082"

  - job_name: 'lxc-containers'
    static_configs:
      - targets:
{% set bastion_hosts = groups.get('bastion_hosts', []) %}
{% for host in groups['lxc_containers'] | difference(bastion_hosts) %}
        - '{{ hostvars[host]["ansible_host"] | default(host) }}:9100'
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:.]+)\..*:.*'
        target_label: instance
        replacement: '$1'

  - job_name: 'proxmox-pve-nas'
    static_configs:
      - targets:
        - '{{ hostvars["pve-exporter-nas"]["ansible_host"] | default("192.168.0.240") }}:9221'

  - job_name: 'media-stack'
    static_configs:
      - targets:
        - '{{ media_stack_ip | default("192.168.0.230") }}:9100'
    relabel_configs:
      - source_labels: [__address__]
        target_label: instance
        replacement: 'media-stack'
