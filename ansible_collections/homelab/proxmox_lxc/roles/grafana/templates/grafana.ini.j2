# Grafana Configuration for Homelab

[server]
# Protocol (http, https, h2, socket)
protocol = http

# The http port to use
http_port = {{ grafana_port }}

# The public facing domain name used to access grafana from a browser
domain = {{ grafana_domain }}

# The full public facing url you use in browser, used for redirects and emails
root_url = {{ grafana_root_url }}

[database]
# Database type
type = {{ grafana_database_type }}

# For SQLite, this is the path where the database file will be stored
path = {{ grafana_database_path }}

[security]
# Default admin user, created on startup
admin_user = {{ grafana_admin_user }}

# Default admin password, can be changed before first start of grafana
admin_password = {{ grafana_admin_password }}

# Used for signing session cookies and other security tokens
# IMPORTANT: Must be unique per deployment - generate with: openssl rand -base64 32
secret_key = {{ grafana_secret_key }}

# Disable creation of admin user on first start of grafana
disable_initial_admin_creation = false

[users]
# Disable user signup / registration
allow_sign_up = {{ grafana_allow_sign_up | lower }}

# Allow non admin users to create organizations
allow_org_create = {{ grafana_allow_org_create | lower }}

# Set to true to automatically assign new users to the default organization (id 1)
auto_assign_org = {{ grafana_auto_assign_org | lower }}

# Default role new users will be automatically assigned
auto_assign_org_role = {{ grafana_auto_assign_org_role }}

[auth]
# Login cookie name
login_cookie_name = grafana_sess

[auth.anonymous]
# Enable anonymous access
enabled = false

[log]
# Either "console", "file", "syslog"
mode = {{ grafana_log_mode }}

# Log level. Available levels are "trace", "debug", "info", "warn", "error", "critical"
level = {{ grafana_log_level }}

[paths]
# Path to where grafana can store temp files, sessions, and the sqlite3 db (if that is used)
data = {{ grafana_data_dir }}

# Directory where grafana can store logs
logs = {{ grafana_logs_dir }}

# Directory where grafana will automatically scan and look for plugins
plugins = {{ grafana_plugins_dir }}

# Directory where grafana stores dashboards
provisioning = {{ grafana_provisioning_dir }}

[analytics]
# Server reporting, sends usage counters to stats.grafana.org every 24 hours
reporting_enabled = false

[snapshots]
# External snapshot publish endpoint
external_enabled = false
