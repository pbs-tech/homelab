[DEFAULT]
# Global Fail2ban configuration
bantime = {{ security_hardening.fail2ban.bantime }}
findtime = {{ security_hardening.fail2ban.findtime }}
maxretry = {{ security_hardening.fail2ban.maxretry }}
ignoreip = {{ security_hardening.fail2ban.ignoreip | join(' ') }}

# Backend for storing ban information
backend = auto

# Email notifications (disabled by default)
{% if security_hardening.fail2ban.mail_enabled | default(false) %}
destemail = {{ security_hardening.fail2ban.dest_email }}
sendername = Fail2Ban-{{ inventory_hostname }}
mta = sendmail
{% endif %}

# Action to take when IP is banned
action = %(action_)s

[sshd]
enabled = true
port = {{ security_hardening.ssh_hardening.port }}
filter = sshd
logpath = /var/log/auth.log
maxretry = {{ security_hardening.fail2ban.maxretry }}

[nginx-http-auth]
enabled = false

[nginx-noscript]  
enabled = false

[nginx-badbots]
enabled = false

[nginx-noproxy]
enabled = false