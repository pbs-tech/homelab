http:
  routers:
{% for service_name, service_config in services.items() %}
    {{ service_name }}-router:
      rule: "Host(`{{ service_config.domain }}`)"
      service: {{ service_name }}-service
{% if traefik_tls_enabled | default(false) %}
      tls:
        certResolver: {{ traefik_ssl_resolver }}
{% endif %}
      middlewares:
        - default-headers
{% endfor %}

    # K3s cluster services router
    k3s-router:
      rule: "Host(`k3s.{{ homelab_domain }}`) || HostRegexp(`{subdomain:[a-z0-9-]+}.k3s.{{ homelab_domain }}`)"
      service: k3s-service
{% if traefik_tls_enabled | default(false) %}
      tls:
        certResolver: {{ traefik_ssl_resolver }}
{% endif %}
      middlewares:
        - default-headers

  serversTransports:
    insecure-skip-verify:
      insecureSkipVerify: true

  services:
{% for service_name, service_config in services.items() %}
    {{ service_name }}-service:
      loadBalancer:
        servers:
          - url: "{{ service_config.scheme | default('http') }}://{{ service_config.ip }}:{{ service_config.port }}"
{% if service_config.insecure_tls | default(false) %}
        serversTransport: insecure-skip-verify
{% endif %}
{% endfor %}

    # K3s cluster service (load balanced across nodes)
    k3s-service:
      loadBalancer:
        servers:
{% for node in k3s_nodes %}
          - url: "https://{{ node.ip }}:6443"
{% endfor %}

  middlewares:
    default-headers:
      headers:
        frameDeny: true
        browserXssFilter: true
        contentTypeNosniff: true
{% if traefik_tls_enabled | default(false) %}
        sslRedirect: true
        forceSTSHeader: true
        stsIncludeSubdomains: true
        stsPreload: true
        stsSeconds: 31536000
        customRequestHeaders:
          X-Forwarded-Proto: "https"
{% endif %}

    secure-headers:
      headers:
        customRequestHeaders:
          X-Forwarded-Proto: "https"
        customResponseHeaders:
          X-Robots-Tag: "none,noarchive,nosnippet,notranslate,noimageindex"
        sslProxyHeaders:
          X-Forwarded-Proto: "https"
