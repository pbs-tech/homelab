global:
  checkNewVersion: false
  sendAnonymousUsage: false

api:
{% if traefik_dashboard_enabled %}
  dashboard: true
  insecure: true
{% else %}
  dashboard: false
{% endif %}

entryPoints:
  web:
    address: ":{{ traefik_http_port }}"
    http:
      redirections:
        entrypoint:
          to: websecure
          scheme: https
  
  websecure:
    address: ":{{ traefik_https_port }}"

certificatesResolvers:
  {{ traefik_ssl_resolver }}:
    acme:
      email: {{ traefik_ssl_email }}
      storage: /var/lib/traefik/acme.json
      httpChallenge:
        entryPoint: web

providers:
  file:
    directory: /etc/traefik/dynamic
    watch: true
  
  # Kubernetes provider for K3s services
  kubernetesIngress:
    endpoints:
      - "https://{{ k3s_api_endpoint }}"
    token: "{{ k3s_service_token | default('') }}"
    certAuthFilePath: /etc/traefik/k3s-ca.crt
    namespaces: []

log:
  level: INFO
  filePath: /var/log/traefik/traefik.log

accessLog:
  filePath: /var/log/traefik/access.log