# Managed by Ansible - {{ ansible_managed }}
# Media stack: Sonarr, Radarr, Bazarr, Prowlarr, qBittorrent (+ Gluetun VPN), Jellyfin
# All services run as PUID={{ media_stack_puid }}/PGID={{ media_stack_pgid }} with NFS at {{ media_stack_nfs_mount }}

networks:
  arr_network:
    driver: bridge

services:

  sonarr:
    image: {{ sonarr_image }}
    container_name: sonarr
    environment:
      - PUID={{ media_stack_puid }}
      - PGID={{ media_stack_pgid }}
      - TZ={{ media_stack_timezone }}
    volumes:
      - {{ media_stack_nfs_mount }}/config/sonarr:/config
      - {{ media_stack_nfs_mount }}:{{ media_stack_nfs_mount }}
    ports:
      - "{{ sonarr_port }}:{{ sonarr_port }}"
    networks:
      - arr_network
    restart: {{ media_stack_restart_policy }}
    mem_limit: {{ sonarr_memory }}

  radarr:
    image: {{ radarr_image }}
    container_name: radarr
    environment:
      - PUID={{ media_stack_puid }}
      - PGID={{ media_stack_pgid }}
      - TZ={{ media_stack_timezone }}
    volumes:
      - {{ media_stack_nfs_mount }}/config/radarr:/config
      - {{ media_stack_nfs_mount }}:{{ media_stack_nfs_mount }}
    ports:
      - "{{ radarr_port }}:{{ radarr_port }}"
    networks:
      - arr_network
    restart: {{ media_stack_restart_policy }}
    mem_limit: {{ radarr_memory }}

  bazarr:
    image: {{ bazarr_image }}
    container_name: bazarr
    environment:
      - PUID={{ media_stack_puid }}
      - PGID={{ media_stack_pgid }}
      - TZ={{ media_stack_timezone }}
    volumes:
      - {{ media_stack_nfs_mount }}/config/bazarr:/config
      - {{ media_stack_nfs_mount }}:{{ media_stack_nfs_mount }}
    ports:
      - "{{ bazarr_port }}:{{ bazarr_port }}"
    networks:
      - arr_network
    restart: {{ media_stack_restart_policy }}
    mem_limit: {{ bazarr_memory }}

  prowlarr:
    image: {{ prowlarr_image }}
    container_name: prowlarr
    environment:
      - PUID={{ media_stack_puid }}
      - PGID={{ media_stack_pgid }}
      - TZ={{ media_stack_timezone }}
    volumes:
      - {{ media_stack_nfs_mount }}/config/prowlarr:/config
    ports:
      - "{{ prowlarr_port }}:{{ prowlarr_port }}"
    networks:
      - arr_network
    restart: {{ media_stack_restart_policy }}
    mem_limit: {{ prowlarr_memory }}

{% if qbittorrent_vpn_enabled | bool %}
  # Gluetun VPN sidecar — qBittorrent runs inside its network namespace.
  # HTTP proxy on port 8888 lets other arr containers (Prowlarr, Sonarr, Radarr) route their
  # outbound traffic through the VPN without sharing the network namespace.
  gluetun:
    image: {{ gluetun_image }}
    container_name: gluetun
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun:/dev/net/tun
    environment:
      - VPN_SERVICE_PROVIDER={{ qbittorrent_vpn_service_provider }}
      - VPN_TYPE={{ qbittorrent_vpn_type }}
{% if qbittorrent_vpn_type == 'openvpn' %}
      - OPENVPN_USER={{ qbittorrent_vpn_openvpn_username }}
      - OPENVPN_PASSWORD={{ qbittorrent_vpn_openvpn_password }}
{% elif qbittorrent_vpn_type == 'wireguard' %}
      - WIREGUARD_PRIVATE_KEY={{ qbittorrent_vpn_wireguard_private_key | default('') }}
{% endif %}
      - SERVER_COUNTRIES={{ qbittorrent_vpn_server_countries }}
      - HTTPPROXY=on
      - HTTPPROXY_LOG=off
    ports:
      - "{{ qbittorrent_webui_port }}:{{ qbittorrent_webui_port }}"
    networks:
      - arr_network
    restart: {{ media_stack_restart_policy }}
    mem_limit: 256m

{% if flaresolverr_enabled | bool %}
  # FlareSolverr — solves Cloudflare bot challenges for Prowlarr indexers.
  # Shares gluetun's namespace so all requests exit via VPN.
  # Reach from Prowlarr at http://gluetun:{{ flaresolverr_port }} (no host port mapping needed).
  flaresolverr:
    image: {{ flaresolverr_image }}
    container_name: flaresolverr
    network_mode: "service:gluetun"
    depends_on:
      - gluetun
    environment:
      - LOG_LEVEL=info
      - TZ={{ media_stack_timezone }}
    restart: {{ media_stack_restart_policy }}
    mem_limit: 512m

{% endif %}
{% endif %}
  qbittorrent:
    image: {{ qbittorrent_image }}
    container_name: qbittorrent
{% if qbittorrent_vpn_enabled | bool %}
    # Shares gluetun's network namespace — no separate networks: key allowed here.
    # Reach the WebUI from other containers via http://gluetun:8080 (not http://qbittorrent:8080).
    network_mode: "service:gluetun"
    depends_on:
      - gluetun
{% else %}
    ports:
      - "{{ qbittorrent_webui_port }}:{{ qbittorrent_webui_port }}"
      - "{{ qbittorrent_torrent_port }}:{{ qbittorrent_torrent_port }}"
      - "{{ qbittorrent_torrent_port }}:{{ qbittorrent_torrent_port }}/udp"
    networks:
      - arr_network
{% endif %}
    environment:
      - PUID={{ media_stack_puid }}
      - PGID={{ media_stack_pgid }}
      - TZ={{ media_stack_timezone }}
      - WEBUI_PORT={{ qbittorrent_webui_port }}
    volumes:
      - {{ media_stack_nfs_mount }}/config/qbittorrent:/config
      - {{ media_stack_nfs_mount }}:{{ media_stack_nfs_mount }}
    restart: {{ media_stack_restart_policy }}
    mem_limit: {{ qbittorrent_memory }}

  jellyfin:
    image: {{ jellyfin_image }}
    container_name: jellyfin
    user: "{{ media_stack_puid }}:{{ media_stack_pgid }}"
    environment:
      - TZ={{ media_stack_timezone }}
    volumes:
      - {{ media_stack_nfs_mount }}/config/jellyfin:/config
      - {{ media_stack_data_dir }}/jellyfin/cache:/cache
      - {{ media_stack_nfs_mount }}:{{ media_stack_nfs_mount }}:ro
    ports:
      - "{{ jellyfin_port }}:{{ jellyfin_port }}"
      - "{{ jellyfin_https_port }}:{{ jellyfin_https_port }}"
    networks:
      - arr_network
{% if jellyfin_hardware_accel | bool %}
    devices:
      - {{ jellyfin_gpu_device }}:{{ jellyfin_gpu_device }}
{% endif %}
    restart: {{ media_stack_restart_policy }}
    mem_limit: {{ jellyfin_memory }}

{% if lettarrboxd_instances | length > 0 %}
{% for instance in lettarrboxd_instances %}
  lettarrboxd-{{ instance.name }}:
    image: {{ lettarrboxd_image }}
    container_name: lettarrboxd-{{ instance.name }}
    environment:
      - LETTERBOXD_URL={{ instance.letterboxd_url }}
      - RADARR_API_URL=http://radarr:{{ radarr_port }}
      - RADARR_API_KEY={{ lettarrboxd_radarr_api_key }}
      - RADARR_QUALITY_PROFILE={{ instance.radarr_quality_profile | default(lettarrboxd_radarr_quality_profile) }}
      - RADARR_MINIMUM_AVAILABILITY={{ instance.radarr_minimum_availability | default(lettarrboxd_radarr_minimum_availability) }}
      - RADARR_ADD_UNMONITORED={{ (instance.radarr_add_unmonitored | default(lettarrboxd_radarr_add_unmonitored)) | bool | lower }}
      - CHECK_INTERVAL_MINUTES={{ instance.check_interval | default(lettarrboxd_check_interval) }}
      - DATA_DIR=/data
    volumes:
      - {{ media_stack_nfs_mount }}/config/lettarrboxd/{{ instance.name }}:/data
    networks:
      - arr_network
    depends_on:
      - radarr
    restart: {{ media_stack_restart_policy }}
    mem_limit: {{ lettarrboxd_memory }}
{% endfor %}
{% endif %}
