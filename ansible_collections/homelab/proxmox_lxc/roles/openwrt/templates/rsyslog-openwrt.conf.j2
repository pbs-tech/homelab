# Rsyslog configuration for receiving OpenWrt logs
# Managed by Ansible - do not edit manually

# Load UDP syslog reception module
module(load="imudp")
input(type="imudp" port="{{ openwrt_remote_syslog_port | default(514) }}")

# Template for OpenWrt log messages
template(name="OpenWrtLogFormat" type="string"
    string="/var/log/openwrt/%HOSTNAME%/%$YEAR%-%$MONTH%-%$DAY%.log")

# Filter OpenWrt logs to dedicated directory
if $fromhost-ip == '{{ openwrt_lan_ip | default("192.168.1.1") }}' then {
    action(type="omfile" dynaFile="OpenWrtLogFormat")
    stop
}
