#!/bin/bash

OPENWRT_DIR="/opt/openwrt"
OPENWRT_IMG="$OPENWRT_DIR/openwrt.qcow2"
OPENWRT_PID="/var/run/openwrt.pid"
OPENWRT_MONITOR="/var/run/openwrt.monitor"

case "$1" in
    start)
        if [ -f "$OPENWRT_PID" ]; then
            echo "OpenWrt is already running (PID: $(cat $OPENWRT_PID))"
            exit 1
        fi
        
        echo "Starting OpenWrt router..."
        
        # Create virtual network interfaces if needed
        if ! ip link show br-openwrt >/dev/null 2>&1; then
            ip link add br-openwrt type bridge
            ip link set br-openwrt up
        fi
        
        # Start QEMU with OpenWrt
        qemu-system-x86_64 \
            -enable-kvm \
            -m 512 \
            -smp 2 \
            -drive file="$OPENWRT_IMG",format=qcow2 \
            -netdev bridge,id=wan,br=br-wan \
            -device virtio-net-pci,netdev=wan,mac=52:54:00:12:34:56 \
            -netdev bridge,id=lan,br=br-openwrt \
            -device virtio-net-pci,netdev=lan,mac=52:54:00:12:34:57 \
            -nographic \
            -daemonize \
            -pidfile "$OPENWRT_PID" \
            -monitor unix:"$OPENWRT_MONITOR",server,nowait \
            -serial file:/var/log/openwrt/console.log
        
        echo "OpenWrt started successfully"
        ;;
        
    stop)
        if [ ! -f "$OPENWRT_PID" ]; then
            echo "OpenWrt is not running"
            exit 1
        fi
        
        echo "Stopping OpenWrt router..."
        
        # Send shutdown command via monitor
        echo "system_powerdown" | socat - unix-connect:"$OPENWRT_MONITOR" 2>/dev/null
        
        # Wait for graceful shutdown
        sleep 5
        
        # Force kill if still running
        if [ -f "$OPENWRT_PID" ]; then
            PID=$(cat "$OPENWRT_PID")
            if kill -0 "$PID" 2>/dev/null; then
                kill "$PID"
                sleep 2
                if kill -0 "$PID" 2>/dev/null; then
                    kill -9 "$PID"
                fi
            fi
            rm -f "$OPENWRT_PID"
        fi
        
        rm -f "$OPENWRT_MONITOR"
        echo "OpenWrt stopped successfully"
        ;;
        
    restart)
        $0 stop
        sleep 2
        $0 start
        ;;
        
    status)
        if [ -f "$OPENWRT_PID" ]; then
            PID=$(cat "$OPENWRT_PID")
            if kill -0 "$PID" 2>/dev/null; then
                echo "OpenWrt is running (PID: $PID)"
                exit 0
            else
                echo "OpenWrt is not running (stale PID file)"
                rm -f "$OPENWRT_PID"
                exit 1
            fi
        else
            echo "OpenWrt is not running"
            exit 1
        fi
        ;;
        
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac