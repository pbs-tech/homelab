[Unit]
Description=Home Assistant Docker Container
Documentation=https://www.home-assistant.io/
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=docker
WorkingDirectory={{ homeassistant_data_dir }}

# Docker compose commands
ExecStartPre=-/usr/bin/docker compose -f {{ homeassistant_data_dir }}/docker-compose.yml pull
ExecStart=/usr/bin/docker compose -f {{ homeassistant_data_dir }}/docker-compose.yml up
ExecStop=/usr/bin/docker compose -f {{ homeassistant_data_dir }}/docker-compose.yml down
ExecReload=/usr/bin/docker compose -f {{ homeassistant_data_dir }}/docker-compose.yml restart

Restart=always
RestartSec=10s
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
