# Home Assistant Configuration
# Managed by Ansible - Manual additions should go below the managed section

# Basic configuration
homeassistant:
  name: {{ homeassistant_name }}
  latitude: {{ homeassistant_latitude }}
  longitude: {{ homeassistant_longitude }}
  elevation: {{ homeassistant_elevation }}
  unit_system: {{ homeassistant_unit_system }}
  time_zone: {{ homeassistant_time_zone }}
  currency: {{ homeassistant_currency }}
  country: {{ homeassistant_country }}
{% if homeassistant_external_url %}
  external_url: {{ homeassistant_external_url }}
{% endif %}
{% if homeassistant_internal_url %}
  internal_url: {{ homeassistant_internal_url }}
{% endif %}

# Default configuration
default_config:

# HTTP configuration for reverse proxy
http:
  use_x_forwarded_for: true
  trusted_proxies:
{% for proxy in homeassistant_trusted_proxies %}
    - {{ proxy }}
{% endfor %}
{% if homeassistant_ssl_enabled %}
  ssl_certificate: /config/ssl/fullchain.pem
  ssl_key: /config/ssl/privkey.pem
{% endif %}

# Recorder configuration (database)
recorder:
  purge_keep_days: {{ homeassistant_db_purge_keep_days }}
  commit_interval: {{ homeassistant_db_commit_interval }}
{% if homeassistant_db_type == 'postgresql' %}
  db_url: postgresql://{{ homeassistant_db_user }}:{{ homeassistant_db_password }}@{{ homeassistant_db_host }}:{{ homeassistant_db_port }}/{{ homeassistant_db_name }}
{% endif %}

# Logger configuration
logger:
  default: info
  logs:
    homeassistant.core: warning
    homeassistant.components.http.ban: warning

{% if homeassistant_mqtt_enabled %}
# MQTT configuration
mqtt:
  broker: {{ homeassistant_mqtt_broker }}
  port: {{ homeassistant_mqtt_port }}
{% if homeassistant_mqtt_user %}
  username: {{ homeassistant_mqtt_user }}
  password: !secret mqtt_password
{% endif %}
  discovery: {{ homeassistant_mqtt_discovery | lower }}
{% endif %}

# Include additional configuration files
automation: !include automations.yaml
script: !include scripts.yaml
scene: !include scenes.yaml

# === Add your custom configuration below this line ===
