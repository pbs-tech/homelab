# WireGuard client config for {{ item.name }}
# Generated by Ansible — server public key is pre-populated
# IMPORTANT: Replace PrivateKey with THIS CLIENT'S private key (not the server's, not your public key)
# Generate with: wg genkey

[Interface]
PrivateKey = {{ item.private_key | default('REPLACE_WITH_YOUR_CLIENT_PRIVATE_KEY') }}
Address = {{ item.allowed_ips }}
{% if wireguard_client_dns_method | default('systemd-resolved') == 'systemd-resolved' %}
PostUp = resolvectl dns %i {{ wireguard_dns_servers | join(' ') }}; resolvectl domain %i ~homelab.lan
PostDown = resolvectl revert %i
{% elif wireguard_client_dns_method | default('systemd-resolved') == 'resolvconf' %}
PostUp = resolvconf -a %i -m 0 -x
PostDown = resolvconf -d %i
{% endif %}

[Peer]
# Server public key (WireGuard LXC at {{ wireguard_server_ip }})
PublicKey = {{ server_publickey_result.stdout }}
{% if item.preshared_key is defined and 'REPLACE' not in item.preshared_key %}
PresharedKey = {{ item.preshared_key }}
{% endif %}
Endpoint = {{ wireguard_public_endpoint }}:{{ wireguard_port }}
AllowedIPs = {{ wireguard_allowed_networks | join(', ') }}
PersistentKeepalive = {{ item.persistent_keepalive | default(25) }}
