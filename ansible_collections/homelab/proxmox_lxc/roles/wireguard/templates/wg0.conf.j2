# WireGuard Server Configuration - Secure Homelab Access
[Interface]
# Server private key (generated automatically or from vault)
PrivateKey = {{ wireguard_server_private_key }}
# Server IP in VPN subnet
Address = {{ wireguard_server_ip }}
# Port for WireGuard traffic
ListenPort = {{ wireguard_port }}
# Save configuration on shutdown
SaveConfig = false

# Firewall rules for NAT/forwarding
# Detect the default interface dynamically
PostUp = iptables -A FORWARD -i %i -j ACCEPT; iptables -A FORWARD -o %i -j ACCEPT; iptables -t nat -A POSTROUTING -s {{ wireguard_server_network }} -o $(ip route show default | awk '/default/ {print $5}' | head -1) -j MASQUERADE
PostDown = iptables -D FORWARD -i %i -j ACCEPT; iptables -D FORWARD -o %i -j ACCEPT; iptables -t nat -D POSTROUTING -s {{ wireguard_server_network }} -o $(ip route show default | awk '/default/ {print $5}' | head -1) -j MASQUERADE

# Security settings
MTU = {{ wireguard_mtu }}

{% for client in wireguard_clients %}
{% if client.public_key is defined and 'REPLACE' not in client.public_key %}
# {{ client.name }} - {{ client.description | default('') }}
[Peer]
PublicKey = {{ client.public_key }}
AllowedIPs = {{ client.allowed_ips }}
{% if client.preshared_key is defined and 'REPLACE' not in client.preshared_key %}
PresharedKey = {{ client.preshared_key }}
{% endif %}
{% if client.persistent_keepalive is defined %}
PersistentKeepalive = {{ client.persistent_keepalive }}
{% endif %}

{% endif %}
{% endfor %}
