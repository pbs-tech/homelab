#!/bin/bash
# K3s security monitoring script for {{ inventory_hostname }}

LOG_FILE="/var/log/k3s-security-monitor.log"
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
HOSTNAME="{{ inventory_hostname }}"

# Function to log messages
log_message() {
    echo "[$TIMESTAMP] $HOSTNAME: $1" >> $LOG_FILE
}

# Check for suspicious login attempts
check_logins() {
    FAILED_LOGINS=$(grep "Failed password" /var/log/auth.log | grep "$(date '+%b %d')" | wc -l)
    if [ $FAILED_LOGINS -gt 5 ]; then
        log_message "WARNING: $FAILED_LOGINS failed login attempts today"
    fi
}

# Check disk space (important for Pi nodes)
check_disk_space() {
    DISK_USAGE=$(df / | awk 'NR==2 {print $5}' | sed 's/%//')
    if [ $DISK_USAGE -gt 80 ]; then
        log_message "WARNING: Disk usage is ${DISK_USAGE}%"
    fi

    # Check /var/log specifically for Pi nodes
    LOG_USAGE=$(df /var/log | awk 'NR==2 {print $5}' | sed 's/%//')
    if [ $LOG_USAGE -gt 75 ]; then
        log_message "WARNING: /var/log usage is ${LOG_USAGE}%"
    fi
}

# Check K3s services
check_k3s_services() {
{% if inventory_hostname in groups['server'] %}
    # Check K3s server
    if ! systemctl is-active --quiet k3s; then
        log_message "ERROR: K3s server service is not running"
    fi

    # Check API server accessibility
    if ! curl -k -s https://localhost:6443/readyz > /dev/null 2>&1; then
        log_message "ERROR: K3s API server not accessible"
    fi
{% endif %}

{% if inventory_hostname in groups['agent'] %}
    # Check K3s agent
    if ! systemctl is-active --quiet k3s-agent; then
        log_message "ERROR: K3s agent service is not running"
    fi

    # Check kubelet
    if ! curl -s http://localhost:10248/healthz > /dev/null 2>&1; then
        log_message "ERROR: Kubelet not responding"
    fi
{% endif %}

    # Check avahi-daemon for .local domains
    if ! systemctl is-active --quiet avahi-daemon; then
        log_message "WARNING: avahi-daemon is not running (.local domains unavailable)"
    fi

    # Check UFW status
    if ! ufw status | grep -q "Status: active"; then
        log_message "ERROR: UFW firewall is not active"
    fi

    # Check Fail2ban status
    if ! systemctl is-active --quiet fail2ban; then
        log_message "ERROR: Fail2ban is not running"
    fi
}

# Check for high resource usage (Pi-specific)
check_resources() {
    # Check memory usage
    MEMORY_USAGE=$(free | awk 'FNR==2{printf "%.0f", $3/($3+$4)*100}')
    if [ $MEMORY_USAGE -gt 85 ]; then
        log_message "WARNING: Memory usage is ${MEMORY_USAGE}%"
    fi

    # Check CPU temperature (Pi-specific)
    if [ -f /opt/vc/bin/vcgencmd ]; then
        TEMP=$(vcgencmd measure_temp | sed 's/temp=//' | sed 's/°C//')
        TEMP_INT=${TEMP%.*}
        if [ $TEMP_INT -gt 70 ]; then
            log_message "WARNING: Pi temperature is ${TEMP}"
        fi
    fi

    # Check for high CPU usage processes
    HIGH_CPU=$(ps aux --sort=-%cpu | awk 'NR<=6 && $3>50.0 {print $11}' | grep -v "COMMAND")
    if [ ! -z "$HIGH_CPU" ]; then
        log_message "INFO: High CPU usage detected: $HIGH_CPU"
    fi
}

# Check network connectivity
check_network() {
    # Test connectivity to other cluster nodes
{% for host in groups['k3s_cluster'] %}
{% if host != inventory_hostname %}
    if ! ping -c 1 {{ hostvars[host]['ansible_host'] }} > /dev/null 2>&1; then
        log_message "WARNING: Cannot reach {{ host }} at {{ hostvars[host]['ansible_host'] }}"
    fi
{% endif %}
{% endfor %}

    # Test .local domain resolution
    if ! nslookup {{ inventory_hostname }}.local > /dev/null 2>&1; then
        log_message "WARNING: .local domain resolution not working for {{ inventory_hostname }}.local"
    fi
}

# Main execution
log_message "Starting K3s security monitoring check"
check_logins
check_disk_space
check_k3s_services
check_resources
check_network
log_message "K3s security monitoring check completed"

# Rotate log file if it gets too large (Pi storage friendly)
if [ -f "$LOG_FILE" ] && [ $(stat -f%z "$LOG_FILE" 2>/dev/null || stat -c%s "$LOG_FILE") -gt 524288 ]; then
    mv "$LOG_FILE" "${LOG_FILE}.old"
    touch "$LOG_FILE"
fi
