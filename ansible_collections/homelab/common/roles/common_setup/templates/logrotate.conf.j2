# {{ ansible_managed }}
# Logrotate configuration for {{ inventory_hostname }}

/var/log/syslog
/var/log/auth.log
/var/log/kern.log
/var/log/cron.log
{
    rotate {{ security_config.log_retention_days | default(30) }}
    daily
    missingok
    notifempty
    compress
    delaycompress
    sharedscripts
    postrotate
        /usr/lib/rsyslog/rsyslog-rotate
    endscript
}
