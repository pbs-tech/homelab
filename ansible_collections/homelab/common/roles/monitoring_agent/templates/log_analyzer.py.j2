#!/usr/bin/env python3
"""Log analyzer for {{ inventory_hostname }}."""

import json
import re
import sys
from datetime import datetime
from pathlib import Path

LOG_FILE = "{{ monitoring_log_dir }}/log_analysis.log"

LOG_PATHS = [
{% for path in log_collection.paths %}
    "{{ path }}",
{% endfor %}
]

PATTERNS = [
{% for pattern in log_analysis.patterns %}
    {"name": "{{ pattern.name }}", "regex": re.compile(r"{{ pattern.regex }}"), "action": "{{ pattern.action }}"},
{% endfor %}
]


def analyze_file(path, patterns):
    """Analyze a single log file for patterns."""
    counts = {p["name"]: 0 for p in patterns}
    try:
        with open(path) as f:
            for line in f:
                for pattern in patterns:
                    if pattern["regex"].search(line):
                        counts[pattern["name"]] += 1
    except (FileNotFoundError, PermissionError):
        pass
    return counts


def main():
    timestamp = datetime.utcnow().isoformat()
    results = {"timestamp": timestamp, "host": "{{ inventory_hostname }}", "files": {}}

    for log_path in LOG_PATHS:
        if Path(log_path).exists():
            results["files"][log_path] = analyze_file(log_path, PATTERNS)

    with open(LOG_FILE, "a") as f:
        f.write(json.dumps(results) + "\n")


if __name__ == "__main__":
    main()
