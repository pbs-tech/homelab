---
version: "{{ monitoring_agent_version }}"
host: "{{ inventory_hostname }}"
environment: "{{ homelab_environment | default('production') }}"

collection:
  interval: {{ performance_metrics.collection_interval | default(60) }}
  retention_days: {{ performance_metrics.retention_days | default(30) }}

log_paths:
{% for path in log_collection.paths %}
  - {{ path }}
{% endfor %}

thresholds:
  cpu: {{ health_checks.checks | selectattr('name', 'equalto', 'system_resources') | map(attribute='thresholds') | map(attribute='cpu') | first | default(90) }}
  memory: {{ health_checks.checks | selectattr('name', 'equalto', 'system_resources') | map(attribute='thresholds') | map(attribute='memory') | first | default(90) }}
  disk: {{ health_checks.checks | selectattr('name', 'equalto', 'system_resources') | map(attribute='thresholds') | map(attribute='disk') | first | default(95) }}
