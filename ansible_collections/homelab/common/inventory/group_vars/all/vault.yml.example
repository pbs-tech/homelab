---
# Ansible Vault encrypted file for shared secrets across all collections
# Encrypt this file with: ansible-vault encrypt vault.yml

# Proxmox API Token Configuration (shared across collections)
# Generate tokens with appropriate scopes for each use case
vault_proxmox_api_tokens:
  pve_mac:
    token_id: root@pam!homelab-automation
    token_secret: your_pve_mac_api_token_secret_here
    # Required privileges: VM.Allocate, VM.Config, VM.Console, VM.PowerMgmt, Datastore.AllocateSpace
  pve_nas:
    token_id: root@pam!homelab-automation
    token_secret: your_pve_nas_api_token_secret_here
    # Required privileges: VM.Allocate, VM.Config, VM.Console, VM.PowerMgmt, Datastore.AllocateSpace

# Legacy support for migration period only
vault_proxmox_passwords:
  pve_mac: your_legacy_pve_mac_password_here
  pve_nas: your_legacy_pve_nas_password_here

# SSL Configuration
vault_ssl_email: admin@homelab.local

# Service Secrets - REQUIRED for deployment
# Grafana
vault_grafana_admin_password: "your-grafana-admin-password"
# Generate with: openssl rand -base64 32
vault_grafana_secret_key: "your-grafana-secret-key-base64"

# AdGuard Home - minimum 12 characters
vault_adguard_admin_password: "your-adguard-admin-password"

# Security Configuration
vault_ansible_vault_password: secure_vault_password_change_me
