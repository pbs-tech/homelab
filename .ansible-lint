---
profile: production

exclude_paths:
  - .cache/
  - .github/
  - molecule/
  - .molecule/
  - .venv/
  - venv/
  - node_modules/
  - __pycache__/
  - "*.pyc"
  - .ansible/
  - ansible_collections/ansible/
  - ansible_collections/ansible.posix-2.1.0.info/
  - ansible_collections/community/
  - ansible_collections/community.crypto-3.1.1.info/
  - ansible_collections/community.docker-5.0.6.info/
  - ansible_collections/community.general-12.4.0.info/
  - ansible_collections/community.grafana-2.3.0.info/
  - ansible_collections/community.library_inventory_filtering_v1-1.1.5.info/
  - ansible_collections/community.proxmox-1.5.0.info/
  - ansible_collections/containers/
  - ansible_collections/containers.podman-1.19.0.info/
  - ansible_collections/kubernetes/
  - ansible_collections/kubernetes.core-6.3.0.info/

# Ansible-lint will include all .yml/.yaml files by default
# Use exclude_paths to control what gets linted

skip_list:
  - yaml[line-length] # Handled by yamllint
  - role-name[path] # Allow collection-style role names
  - galaxy[no-changelog] # Collections may not have changelog
  - fqcn[action-core] # Allow core modules without FQCN in collections
  - var-naming[no-role-prefix] # Allow variables without role prefix in vars files
  - yaml[document-start] # Encrypted vault files cannot have --- prepended

warn_list:
  - experimental # Allow experimental rules as warnings
  - yaml[octal-values] # Warn about octal values
  - risky-file-permissions # Warn about risky file permissions

use_default_rules: true

# Additional rules to enable for better security and practices
enable_list:
  - no-log-password
  - no-same-owner
  - name[template]
  - risky-shell-pipe
  - command-instead-of-shell
  - deprecated-command-syntax
  - empty-string-compare
  - literal-compare
  - no-free-form
  - no-jinja-when
  - package-latest
  - risky-octal
  - syntax-check

# No additional rule configuration needed - defaults are appropriate
