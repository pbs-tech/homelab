---
# Vault Variables Example
#
# Copy this file to vault.yml and encrypt it with ansible-vault:
#   cp vault.yml.example vault.yml
#   ansible-vault encrypt vault.yml
#
# To edit encrypted vault:
#   ansible-vault edit vault.yml
#
# To use with playbooks:
#   ansible-playbook site.yml --ask-vault-pass
#   or use a vault password file:
#   ansible-playbook site.yml --vault-password-file ~/.vault_pass

# Proxmox API Token Authentication (preferred method)
# Create API tokens in Proxmox: Datacenter > Permissions > API Tokens
# Required privileges: VM.Allocate, VM.Config.*, VM.Console, VM.PowerMgmt,
#                      Datastore.AllocateSpace, Sys.Audit
vault_proxmox_api_tokens:
  pve_mac:
    # Format: user@realm!token-name
    token_id: "root@pam!ansible"
    token_secret: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
  pve_nas:
    token_id: "root@pam!ansible"
    token_secret: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Proxmox Password Authentication (legacy fallback)
# Only used if API tokens are not configured
vault_proxmox_passwords:
  pve_mac: "your-pve-mac-password"
  pve_nas: "your-pve-nas-password"

# SSL/TLS Configuration
# Email for Let's Encrypt certificate notifications
vault_ssl_email: "admin@example.com"

# Service Secrets - REQUIRED for deployment
# Grafana
vault_grafana_admin_password: "your-grafana-admin-password"
# Generate with: openssl rand -base64 32
vault_grafana_secret_key: "your-grafana-secret-key-base64"

# AdGuard Home - minimum 12 characters
vault_adguard_admin_password: "your-adguard-admin-password"

# WireGuard client preshared keys (one per client peer)
# Generate with: wg genpsk
vault_wireguard_client_preshared_key_control_machine: "your-preshared-key-base64"

# qBittorrent WebUI - minimum 8 characters, must not be 'adminadmin'
vault_qbittorrent_admin_password: "your-qbittorrent-admin-password"

# NordVPN OpenVPN service credentials (for qBittorrent VPN via Gluetun)
# Obtain from: https://my.nordaccount.com/dashboard/nordvpn/manual-configuration/
# Select "OpenVPN" - these credentials never rotate and require no key management.
vault_nordvpn_openvpn_username: "your-nordvpn-service-username"
vault_nordvpn_openvpn_password: "your-nordvpn-service-password"

# TrueNAS - API key for REST API access (used by truenas-network tag)
# Generate via TrueNAS shell: midclt call api_key.create '{"name": "ansible", "allowlist": []}'
vault_truenas_api_key: "your-truenas-api-key"

# Zot OCI Registry credentials
# Admin user for Zot registry management UI and API access
vault_zot_admin_user: "admin"
vault_zot_admin_password: "CHANGEME_min12chars"

# Additional secrets can be added here as needed
